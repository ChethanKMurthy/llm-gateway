# Copy to .env (or just export these). The gateway works fully WITHOUT any keys —
# every provider falls back to a faithful simulator. Add a key and that provider
# automatically switches to live calls; everything else stays simulated.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# XAI_API_KEY=xai-...          # Grok (xAI). GROK_API_KEY also accepted.
# GROQ_API_KEY=gsk_...         # Groq (GroqCloud — fast open models: Llama, Qwen, gpt-oss)
# GEMINI_API_KEY=...
# OLLAMA_HOST=http://localhost:11434

# Demo tuning: how much of the simulated latency to actually wait (0..1).
# Lower = snappier demo. Default 0.18.
# GATEWAY_SIM_LATENCY_SCALE=0.18
